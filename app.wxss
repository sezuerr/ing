page {
  --color-surface: #fff9e6;
  --color-card-bg: #fafaf7;
  --color-card-panel: rgba(255, 255, 255, 0.75);
  --color-text-primary: #15130d;
  --color-text-secondary: #8a806d;
  --color-text-tertiary: #7d735e;
  --color-text-inverse: #ffffff;
  --color-accent: #ffc107;
  --color-accent-light: #ffd84d;
  --color-accent-dark: #ffb300;
  --color-accent-gradient: linear-gradient(135deg, #ffc107, #ff9800);
  --color-accent-soft: #f2efe3;
  --color-accent-glow: rgba(255, 193, 7, 0.25);
  --color-accent-border: rgba(255, 193, 7, 0.12);
  --color-accent-shadow: rgba(255, 193, 7, 0.08);
  --color-danger: #ff4d4f;
  --color-danger-soft: rgba(255, 77, 79, 0.15);
  --color-danger-light: #ff674d;
  --color-info: #4a90e2;
  --color-info-soft: rgba(74, 144, 226, 0.15);
  --color-border: rgba(21, 19, 13, 0.08);
  --color-border-strong: rgba(21, 19, 13, 0.14);
  --color-dark-fill: linear-gradient(135deg, #15130d, #342e22);

  min-height: 100%;
  background: var(--color-surface);
  color: var(--color-text-primary);
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  letter-spacing: 0;
}

button {
  font: inherit;
}

.page {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 28rpx calc(148rpx + env(safe-area-inset-bottom));
}

/* 自定义导航栏模式下给页面顶部留出状态栏空间 */
.page-custom-nav {
  padding-top: calc(96rpx + env(safe-area-inset-top));
}

.section {
  margin-bottom: 28rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  color: var(--color-text-primary);
  font-size: 30rpx;
  font-weight: 700;
}

.panel {
  border: 2rpx solid var(--color-accent-border);
  border-radius: 28rpx;
  background: var(--color-card-panel);
  box-shadow:
    0 12rpx 36rpx var(--color-accent-shadow),
    0 4rpx 12rpx rgba(21, 19, 13, 0.04);
}

.primary-btn {
  height: 92rpx;
  border-radius: 999rpx;
  background: var(--color-accent-gradient);
  color: var(--color-text-primary);
  font-weight: 800;
  line-height: 92rpx;
  box-shadow: 0 12rpx 28rpx var(--color-accent-glow);
}

.ghost-btn {
  border: 2rpx solid var(--color-border-strong);
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--color-text-primary);
}

.muted {
  color: var(--color-text-secondary);
}

.chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: var(--color-accent-soft);
  color: #4a4436;
  font-size: 24rpx;
  line-height: 56rpx;
}

.chip-icon {
  font-size: 24rpx;
  line-height: 1;
}

.hairline {
  border-bottom: 2rpx solid var(--color-border);
}

.hairline:last-child {
  border-bottom: 0;
}

.corner-bulb {
  position: absolute;
  top: calc(16rpx + env(safe-area-inset-top));
  left: 28rpx;
  z-index: 50;
  width: 72rpx;
  height: 72rpx;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--color-accent-light), var(--color-accent-dark));
  box-shadow: 0 8rpx 28rpx rgba(255, 193, 7, 0.4);
}

.corner-bulb .footer-icon {
  width: 52rpx;
  height: 52rpx;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid rgba(255, 193, 7, 0.2);
  border-radius: 14rpx;
  background: #fffdf7;
  color: var(--color-text-primary);
}

.input {
  height: 88rpx;
  padding: 0 22rpx;
}

.textarea {
  min-height: 240rpx;
  padding: 22rpx;
}
