.item-wrap {
  position: relative;
  overflow: hidden;
}

.reveal-action {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  display: flex;
  width: 72px;
  align-items: center;
  justify-content: center;
  background: #ff4d4f;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
}

.item {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 20rpx 4rpx;
  background: #fafaf7;
  border-bottom: 2rpx solid rgba(21, 19, 13, 0.08);
  transition: transform 0.15s ease-out;
}

.item-wrap:last-child .item {
  border-bottom: 0;
}

.avatar {
  display: flex;
  width: 88rpx;
  height: 88rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: #15130d;
  color: #ffd84d;
  font-weight: 900;
}

.body {
  min-width: 0;
  flex: 1;
  margin-left: 18rpx;
}

.topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.name {
  color: #15130d;
  font-size: 30rpx;
  font-weight: 850;
}

.time {
  flex: 0 0 auto;
  margin-left: 12rpx;
  color: #a49b86;
  font-size: 22rpx;
}

.bottomline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.last {
  display: block;
  overflow: hidden;
  min-width: 0;
  flex: 1;
  color: #7d735e;
  font-size: 24rpx;
  line-height: 34rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.badge {
  min-width: 32rpx;
  height: 32rpx;
  flex: 0 0 auto;
  padding: 0 8rpx;
  margin-left: 12rpx;
  border-radius: 999rpx;
  background: #ff674d;
  color: #fff;
  font-size: 20rpx;
  line-height: 32rpx;
  text-align: center;
}
