.item {
  display: flex;
  align-items: center;
  padding: 20rpx 4rpx;
  border-bottom: 2rpx solid rgba(21, 19, 13, 0.08);
}

.item:last-child {
  border-bottom: 0;
}

.avatar {
  display: flex;
  width: 82rpx;
  height: 82rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: #ffd84d;
  color: #15130d;
  font-weight: 900;
}

.body {
  min-width: 0;
  margin-left: 18rpx;
}

.topline {
  display: flex;
  align-items: center;
}

.title {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #15130d;
  font-size: 28rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time {
  flex: 0 0 auto;
  margin-left: 12rpx;
  color: #a49b86;
  font-size: 22rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  flex: 0 0 auto;
  margin-left: 10rpx;
  border-radius: 999rpx;
  background: #ff674d;
}

.desc {
  display: block;
  overflow: hidden;
  margin-top: 8rpx;
  color: #7d735e;
  font-size: 24rpx;
  line-height: 34rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}
