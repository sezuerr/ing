<view class="card" wx:if="{{post}}">
  <!-- 头部 -->
  <view class="card-header">
    <view class="header-left">
      <view class="avatar {{!isMine && !isFriend ? 'avatar-anon' : ''}}">
        <image wx:if="{{(isMine || isFriend) && authorAvatarUrl}}" src="{{authorAvatarUrl}}" mode="aspectFill" />
        <text wx:elif="{{!isMine && !isFriend}}" class="avatar-emoji">{{post.icon || '💡'}}</text>
        <text wx:else>{{avatarText}}</text>
      </view>
      <view class="header-info">
        <view class="header-name-row">
          <text class="header-name">{{displayName}}</text>
          <text wx:if="{{likedMe && !matched}}" class="badge badge-liked">点亮过你</text>
          <text wx:elif="{{matched}}" class="badge badge-matched">已配对</text>
        </view>
        <text class="header-time">{{timeText}}{{post.universityName ? ' · ' + post.universityName : ''}} · {{post.distanceText || '距离未知'}}</text>
      </view>
    </view>
    <view wx:if="{{!isMine}}" class="report-btn" catchtap="openReport">
      <image class="report-icon" src="/icons/hand.svg" mode="aspectFit" />
    </view>
  </view>

  <!-- 正文 -->
  <view class="card-body">
    <text wx:if="{{post.title}}" class="post-title">{{post.title}}</text>
    <text class="post-text">{{post.body}}</text>
  </view>

  <!-- 图片 -->
  <view wx:if="{{post.imageUrls && post.imageUrls.length}}" class="images-grid images-{{imageLayout}}">
    <image wx:for="{{post.imageUrls}}" wx:for-index="idx" wx:key="*this" class="grid-image" mode="aspectFill" src="{{item}}" data-urls="{{post.imageUrls}}" data-index="{{idx}}" catchtap="previewImage" />
  </view>

  <!-- 评论树 -->
  <view wx:if="{{_commentList.length}}" class="comments-section">
    <view wx:for="{{_commentList}}" wx:key="comment._id" class="comment-thread {{item.depth > 0 ? 'has-thread' : ''}}" style="margin-left: {{item.depth > 0 ? 48 : 0}}rpx">
      <view class="comment-row {{replyingTo === item.comment._id ? 'comment-row-active' : ''}}" bindlongpress="onLongPressComment" catchtap="onReplyComment" data-cid="{{item.comment._id}}" data-name="{{item.comment.fromUser ? item.comment.fromUser.nickName : ''}}" data-mine="{{currentUserId === item.comment.fromUserId}}">
        <view class="comment-avatar {{!item.comment.fromUser ? 'anon' : ''}}">
          <image wx:if="{{item.comment.fromUser && item.comment.fromUser.avatarUrl}}" src="{{item.comment.fromUser.avatarUrl}}" mode="aspectFill" />
          <text wx:else>匿</text>
        </view>
        <view class="comment-content">
          <view class="comment-name-row">
            <text class="comment-name">{{item.comment.fromUser ? item.comment.fromUser.nickName : '匿名同学'}}</text>
            <text wx:if="{{item.comment.isAuthor}}" class="comment-author-tag">作者</text>
          </view>
          <text class="comment-text">{{item.comment.content}}</text>
        </view>
        <text class="comment-time">{{item.timeText}}</text>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="card-footer">
    <!-- 自己帖子 -->
    <view wx:if="{{isMine}}" class="footer-mine">
      <view class="mine-stat">
        <image class="mine-icon" src="/icons/lightbulb-fill.svg" mode="aspectFit" />
        <text>{{post.likeCount || 0}} 点亮</text>
      </view>
      <view class="mine-stat">
        <image class="mine-icon" src="/icons/chat-1-line.svg" mode="aspectFit" />
        <text>{{post.commentCount || 0}} 回复</text>
      </view>
      <view wx:if="{{canComment}}" class="reply-area">
        <view wx:if="{{replyingTo}}" class="reply-to-bar">
          <text class="reply-to-text">回复 {{replyToName}}</text>
          <text class="reply-cancel" catchtap="cancelReply">取消</text>
        </view>
        <view class="reply-input-row">
          <input class="reply-input" value="{{draft}}" placeholder="回复…" confirm-type="send" adjust-position focus="{{inputFocus}}" bindinput="onDraftInput" bindconfirm="send" bindblur="onReplyBlur" />
          <view class="send-btn" catchtap="send">
            <image class="footer-icon send-icon" src="/icons/send-ins-line.svg" mode="aspectFit" />
          </view>
        </view>
      </view>
    </view>

    <!-- 已点亮 -->
    <view wx:elif="{{liked}}" class="footer-liked {{canComment ? 'footer-liked-has-reply' : ''}}">
      <view class="like-btn liked" catchtap="noop">
        <image class="footer-icon" src="/icons/lightbulb-fill.svg" mode="aspectFit" />
      </view>
      <view wx:if="{{canComment}}" class="reply-area footer-reply-area">
        <view wx:if="{{replyingTo}}" class="reply-to-bar">
          <text class="reply-to-text">回复 {{replyToName}}</text>
          <text class="reply-cancel" catchtap="cancelReply">取消</text>
        </view>
        <view class="reply-input-row">
          <input class="reply-input" value="{{draft}}" placeholder="说点什么…" confirm-type="send" adjust-position focus="{{inputFocus}}" bindinput="onDraftInput" bindconfirm="send" bindblur="onReplyBlur" />
          <view class="send-btn" catchtap="send">
            <image class="footer-icon send-icon" src="/icons/send-ins-line.svg" mode="aspectFit" />
          </view>
        </view>
      </view>
      <text wx:else class="footer-label">已点亮</text>
    </view>

    <!-- 未点亮但可回复 -->
    <view wx:elif="{{canComment}}" class="footer-default-with-reply">
      <view class="like-btn" catchtap="like">
        <image class="footer-icon" src="/icons/lightbulb-line.svg" mode="aspectFit" />
      </view>
      <view class="reply-area footer-reply-area">
        <view wx:if="{{replyingTo}}" class="reply-to-bar">
          <text class="reply-to-text">回复 {{replyToName}}</text>
          <text class="reply-cancel" catchtap="cancelReply">取消</text>
        </view>
        <view class="reply-input-row">
          <input class="reply-input" value="{{draft}}" placeholder="说点什么…" confirm-type="send" adjust-position focus="{{inputFocus}}" bindinput="onDraftInput" bindconfirm="send" bindblur="onReplyBlur" />
          <view class="send-btn" catchtap="send">
            <image class="footer-icon send-icon" src="/icons/send-ins-line.svg" mode="aspectFit" />
          </view>
        </view>
      </view>
    </view>

    <!-- 未点亮 -->
    <view wx:else class="footer-default">
      <view class="like-btn {{bulbLit ? 'glow' : ''}}" catchtap="like">
        <image class="footer-icon" src="/icons/lightbulb-line.svg" mode="aspectFit" />
      </view>
      <text class="footer-label">{{likedMe ? '回点TA' : '点亮'}}</text>
    </view>
  </view>
</view>
