<view class="card" wx:if="{{post}}">
  <view class="tape"></view>
  <block wx:if="{{post.imageUrls && post.imageUrls.length}}">
    <view class="hero">
      <image class="hero-image" mode="aspectFill" src="{{post.imageUrls[0]}}" />
      <view class="hero-overlay"></view>
      <view wx:if="{{!isMine}}" class="report report-hero" catchtap="openReport" aria-label="举报或不感兴趣">
        <image class="report-icon report-icon-hero" src="/icons/hand.svg" mode="aspectFit" />
      </view>
      <view class="identity identity-hero">
        <view class="avatar avatar-hero {{!isMine && !isFriend ? 'avatar-emoji-wrap' : ''}}">
          <image wx:if="{{(isMine || isFriend) && authorAvatarUrl}}" src="{{authorAvatarUrl}}" mode="aspectFill" />
          <text wx:elif="{{!isMine && !isFriend}}" class="avatar-emoji">{{post.icon || '💡'}}</text>
          <text wx:else>{{avatarText}}</text>
        </view>
        <view class="meta-text">
          <view class="name name-hero">
            {{displayName}}
            <text wx:if="{{likedMe && !matched}}" class="liked-me-badge">点亮过你</text>
            <text wx:elif="{{likedByMe && !likedMe && !matched}}" class="liked-me-badge">点亮过ta</text>
            <text wx:elif="{{!likedMe && !matched && !isMine}}" class="not-liked-badge">未点亮</text>
          </view>
          <view wx:if="{{!isMine}}" class="sub sub-hero">{{timeText}} · {{post.distanceText || '距离未知'}} · {{post.universityName || '未知学校'}}</view>
        </view>
      </view>
    </view>

    <view class="body body-floating">
      <view class="content">
        <text class="body-text">{{post.body}}</text>
        <scroll-view wx:if="{{post.imageUrls.length > 1}}" scroll-x class="images">
          <image wx:for="{{post.imageUrls}}" wx:key="*this" class="image" mode="aspectFill" src="{{item}}" />
        </scroll-view>
      </view>

      <view class="footer">
        <view wx:if="{{isMine}}" class="footer-mine">
          <view class="mine-stats">
            <text class="mine-stat-icon">💡</text>
            <text class="mine-stat-count">{{post.likeCount || 0}} 人点亮</text>
          </view>
          <text class="mine-stat-label">{{post.commentCount || 0}} 条私密回复</text>
        </view>
        <view wx:elif="{{matched}}" class="matched-row">
          <view class="icon-btn like-btn liked">
            <image class="footer-icon" src="/icons/lightbulb-fill.svg" mode="aspectFit" />
          </view>
          <view class="reply-area">
            <input class="reply-input" value="{{draft}}" placeholder="回复…" confirm-type="send" adjust-position bindinput="onDraftInput" bindconfirm="send" />
            <view class="icon-btn send-btn" catchtap="send" aria-label="发送">
              <image class="footer-icon send-icon" src="/icons/send-ins-line.svg" mode="aspectFit" />
            </view>
          </view>
        </view>
        <view wx:elif="{{liked}}" class="footer-liked">
          <view class="like-status liked {{bulbLit ? 'glow' : ''}}">
            <image class="footer-icon" src="/icons/lightbulb-fill.svg" mode="aspectFit" />
          </view>
          <text class="wait-text">已点亮</text>
        </view>
        <view wx:else class="footer-default">
          <view class="icon-btn like-btn {{bulbLit ? 'glow' : ''}}" hover-class="like-btn-active" catchtap="like" aria-label="点亮">
            <image class="footer-icon" src="/icons/lightbulb-line.svg" mode="aspectFit" />
          </view>
          <text class="default-bulb-label">{{likedMe ? '回点TA' : '点亮'}}</text>
        </view>
      </view>

      <view wx:if="{{isMine && comments.length}}" class="mine-comments">
        <view wx:for="{{comments}}" wx:key="_id" class="mine-comment">
          <view class="mine-comment-avatar">{{item.fromUser && item.fromUser.nickName ? item.fromUser.nickName.slice(0,1) : '匿'}}</view>
          <view class="mine-comment-right">
            <view class="mine-comment-name">{{item.fromUser ? (item.fromUser.nickName || '好友') : '好友'}}</view>
            <text class="mine-comment-body">{{item.content}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="body">
      <view class="meta">
        <view class="identity">
          <view class="avatar {{!isMine && !isFriend ? 'avatar-emoji-wrap' : ''}}">
            <image wx:if="{{isMine && authorAvatarUrl}}" src="{{authorAvatarUrl}}" mode="aspectFill" />
            <text wx:elif="{{!isMine && !isFriend}}" class="avatar-emoji">{{post.icon || '💡'}}</text>
            <text wx:else>{{avatarText}}</text>
          </view>
          <view class="meta-text">
            <view class="name">
            {{displayName}}
            <text wx:if="{{likedMe && !matched}}" class="liked-me-badge">点亮过你</text>
            <text wx:elif="{{likedByMe && !likedMe && !matched}}" class="liked-me-badge">点亮过ta</text>
            <text wx:elif="{{!likedMe && !matched && !isMine}}" class="not-liked-badge">未点亮</text>
          </view>
            <view wx:if="{{!isMine}}" class="sub">{{timeText}} · {{post.distanceText || '距离未知'}} · {{post.universityName || '未知学校'}}</view>
          </view>
        </view>
        <view wx:if="{{!isMine}}" class="report" catchtap="openReport" aria-label="举报或不感兴趣">
          <image class="report-icon" src="/icons/hand.svg" mode="aspectFit" />
        </view>
      </view>

      <view class="content">
        <text class="body-text">{{post.body}}</text>
      </view>

      <view class="footer">
        <view wx:if="{{isMine}}" class="footer-mine">
          <view class="mine-stats">
            <text class="mine-stat-icon">💡</text>
            <text class="mine-stat-count">{{post.likeCount || 0}} 人点亮</text>
          </view>
          <text class="mine-stat-label">{{post.commentCount || 0}} 条私密回复</text>
        </view>
        <view wx:elif="{{matched}}" class="matched-row">
          <view class="icon-btn like-btn liked">
            <image class="footer-icon" src="/icons/lightbulb-fill.svg" mode="aspectFit" />
          </view>
          <view class="reply-area">
            <input class="reply-input" value="{{draft}}" placeholder="回复…" confirm-type="send" adjust-position bindinput="onDraftInput" bindconfirm="send" />
            <view class="icon-btn send-btn" catchtap="send" aria-label="发送">
              <image class="footer-icon send-icon" src="/icons/send-ins-line.svg" mode="aspectFit" />
            </view>
          </view>
        </view>
        <view wx:elif="{{liked}}" class="footer-liked">
          <view class="like-status liked {{bulbLit ? 'glow' : ''}}">
            <image class="footer-icon" src="/icons/lightbulb-fill.svg" mode="aspectFit" />
          </view>
          <text class="wait-text">已点亮</text>
        </view>
        <view wx:else class="footer-default">
          <view class="icon-btn like-btn {{bulbLit ? 'glow' : ''}}" hover-class="like-btn-active" catchtap="like" aria-label="点亮">
            <image class="footer-icon" src="/icons/lightbulb-line.svg" mode="aspectFit" />
          </view>
          <text class="default-bulb-label">{{likedMe ? '回点TA' : '点亮'}}</text>
        </view>
      </view>

      <view wx:if="{{isMine && comments.length}}" class="mine-comments">
        <view wx:for="{{comments}}" wx:key="_id" class="mine-comment">
          <view class="mine-comment-avatar">{{item.fromUser && item.fromUser.nickName ? item.fromUser.nickName.slice(0,1) : '匿'}}</view>
          <view class="mine-comment-right">
            <view class="mine-comment-name">{{item.fromUser ? (item.fromUser.nickName || '好友') : '好友'}}</view>
            <text class="mine-comment-body">{{item.content}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
