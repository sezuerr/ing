/* ===== 卡片主体 ===== */
.card {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  border-radius: 20rpx;
  background: #fffef8;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06), 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  overflow: hidden;
}

/* ===== 头部 ===== */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 0;
}

.header-left {
  display: flex;
  align-items: center;
  min-width: 0;
  flex: 1;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #15130d, #342e22);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-anon {
  background: rgba(255, 216, 77, 0.15);
}

.avatar-emoji {
  font-size: 38rpx;
  line-height: 1;
}

.avatar text {
  font-size: 32rpx;
  font-weight: 800;
  color: #ffd84d;
}

.header-info {
  margin-left: 18rpx;
  min-width: 0;
  flex: 1;
}

.header-name-row {
  display: flex;
  align-items: center;
}

.header-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #15130d;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 280rpx;
}

.badge {
  display: inline-block;
  padding: 2rpx 12rpx;
  margin-left: 10rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.badge-liked {
  background: linear-gradient(135deg, #ffd84d, #ffb300);
  color: #342e22;
}

.badge-matched {
  background: rgba(21, 19, 13, 0.08);
  color: #8a806d;
}

.header-time {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #8a806d;
}

.report-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.report-icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.4;
}

/* ===== 正文 ===== */
.card-body {
  padding: 20rpx 28rpx 0;
}

.post-title {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
  color: #15130d;
  line-height: 1.35;
  margin-bottom: 10rpx;
}

.post-text {
  display: block;
  font-size: 30rpx;
  color: #342e22;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
}

/* ===== 图片网格（朋友圈式） ===== */
.images-grid {
  padding: 20rpx 28rpx 0;
  display: grid;
  gap: 6rpx;
}

/* 1 张图：大图 */
.images-one {
  grid-template-columns: 1fr;
}
.images-one .grid-image {
  width: 100%;
  height: 380rpx;
  border-radius: 10rpx;
}

/* 2 张图：双列 */
.images-two {
  grid-template-columns: 1fr 1fr;
}
.images-two .grid-image {
  width: 100%;
  height: 260rpx;
  border-radius: 10rpx;
}

/* 3 张图：一大两小 */
.images-grid.images-grid {
  grid-template-columns: 1fr 1fr 1fr;
}
.images-grid .grid-image {
  width: 100%;
  height: 220rpx;
  border-radius: 10rpx;
  background: #eee3bf;
}

/* 4 张图：2x2 */
.images-four {
  grid-template-columns: 1fr 1fr;
}
.images-four .grid-image {
  width: 100%;
  height: 240rpx;
  border-radius: 10rpx;
}

.grid-image {
  background: #eee3bf;
  object-fit: cover;
}

/* ===== 评论区域 ===== */
.comments-section {
  margin: 20rpx 28rpx 0;
  padding: 16rpx 20rpx;
  background: rgba(21, 19, 13, 0.03);
  border-radius: 14rpx;
}

.comment-row {
  display: flex;
  align-items: flex-start;
  padding: 10rpx 0;
  gap: 12rpx;
}

.comment-row + .comment-row {
  border-top: 1rpx solid rgba(21, 19, 13, 0.05);
}

.comment-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #15130d;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.comment-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.comment-avatar text {
  font-size: 22rpx;
  font-weight: 800;
  color: #ffd84d;
}

.comment-avatar.anon {
  background: rgba(21, 19, 13, 0.08);
}

.comment-avatar.anon text {
  color: #8a806d;
}

.comment-content {
  flex: 1;
  min-width: 0;
}

.comment-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.comment-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #342e22;
}

.comment-author-tag {
  padding: 1rpx 8rpx;
  border-radius: 4rpx;
  background: linear-gradient(135deg, #ffd84d, #ffb300);
  font-size: 18rpx;
  font-weight: 700;
  color: #342e22;
}

.comment-text {
  display: block;
  margin-top: 4rpx;
  font-size: 26rpx;
  color: #342e22;
  line-height: 1.45;
  word-break: break-word;
}

.comment-time {
  font-size: 20rpx;
  color: #b8ae98;
  flex-shrink: 0;
  margin-top: 2rpx;
}

/* --- 评论操作按钮 --- */
.comment-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 6rpx;
}

.comment-action-btn {
  font-size: 22rpx;
  color: #8a806d;
}

.comment-delete-btn {
  color: #c94b4b;
}

.comment-row-active {
  background: rgba(255, 193, 7, 0.08);
  border-radius: 12rpx;
  padding: 8rpx 12rpx;
  margin: 0 -12rpx;
}

/* --- 评论树缩进 --- */
.comment-thread.has-thread {
  border-left: 2rpx solid rgba(235, 210, 140, 0.3);
  padding-left: 12rpx;
  margin-bottom: 4rpx;
}

/* ===== 底部操作栏 ===== */
.card-footer {
  padding: 24rpx 28rpx 28rpx;
  display: flex;
  align-items: center;
}

/* --- 自己的帖子 --- */
.footer-mine {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 0;
  width: 100%;
}

.footer-mine .reply-area {
  flex-basis: 100%;
  margin-top: 4rpx;
}

.mine-stat {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #342e22;
}

.mine-icon {
  width: 36rpx;
  height: 36rpx;
}

/* --- 默认/已点亮 --- */
.footer-default,
.footer-liked {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: 100%;
}

.like-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(21, 19, 13, 0.06);
  transition: all 0.2s;
}

.like-btn:active {
  transform: scale(0.9);
}

.like-btn.liked {
  background: linear-gradient(135deg, #ffd84d, #ffb300);
  box-shadow: 0 6rpx 20rpx rgba(255, 179, 0, 0.3);
}

.like-btn.glow {
  background: linear-gradient(135deg, #ffd84d, #ffb300);
  box-shadow: 0 8rpx 28rpx rgba(255, 193, 7, 0.5);
  animation: glow 2s ease-in-out infinite;
}

@keyframes glow {
  0%, 100% { box-shadow: 0 8rpx 28rpx rgba(255, 193, 7, 0.5); }
  50% { box-shadow: 0 8rpx 44rpx rgba(255, 193, 7, 0.7), 0 0 50rpx rgba(255, 152, 0, 0.3); }
}

.footer-icon {
  width: 50rpx;
  height: 50rpx;
}

.footer-label {
  font-size: 24rpx;
  color: #8a806d;
}

/* --- 已点亮 + 有回复栏：水平布局 --- */
.footer-liked-has-reply {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  width: 100%;
}

.footer-liked-has-reply .like-btn.liked {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
}

.footer-liked-has-reply .footer-icon {
  width: 44rpx;
  height: 44rpx;
}

/* --- 未点亮但可回复（点亮过该作者，但未点亮此帖） --- */
.footer-default-with-reply {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  width: 100%;
}

.footer-default-with-reply .like-btn {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
}

.footer-default-with-reply .footer-icon {
  width: 44rpx;
  height: 44rpx;
}

.reply-area {
  display: flex;
  flex-direction: column;
  flex: 1;
  gap: 8rpx;
}

.footer-reply-area {
  flex-direction: column;
}

.reply-to-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx;
}

.reply-to-text {
  font-size: 22rpx;
  color: #ffb300;
  font-weight: 600;
}

.reply-cancel {
  font-size: 22rpx;
  color: #8a806d;
  font-weight: 400;
}

.reply-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.reply-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 40rpx;
  background: rgba(21, 19, 13, 0.04);
  font-size: 28rpx;
  color: #15130d;
}

.send-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #15130d;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.send-icon {
  filter: brightness(0) invert(1);
}
