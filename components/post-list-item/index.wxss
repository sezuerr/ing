.item {
  position: relative;
  display: flex;
  padding: 24rpx 4rpx;
  border-bottom: 1rpx solid rgba(21, 19, 13, 0.06);
}

.item:last-child {
  border-bottom: 0;
}

/* ── 左侧图标 ── */
.icon {
  width: 48rpx;
  flex: 0 0 auto;
  font-size: 34rpx;
  line-height: 1.5;
  padding-top: 2rpx;
}

/* ── 右侧内容 ── */
.content {
  min-width: 0;
  flex: 1;
  margin-left: 16rpx;
}

/* ── 正文 ── */
.body {
  display: -webkit-box;
  overflow: hidden;
  color: var(--color-text-primary);
  font-size: 30rpx;
  font-weight: 400;
  line-height: 1.45;
  letter-spacing: 0..05rpx;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  word-break: break-all;
}

.expanded {
  display: block;
}

/* ── 展开/收起 ── */
.expand-row {
  margin-top: 8rpx;
}

.expand {
  font-size: 26rpx;
  font-weight: 500;
  color: #9d8a5a;
  line-height: 1;
}

/* ── 图片缩略图 ── */
.thumb-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
}

.thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f3f0ea;
}

.thumb-more {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: rgba(21, 19, 13, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #9d8a5a;
  font-weight: 500;
}

/* ── 底部元信息行 ── */
.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.time {
  font-size: 24rpx;
  font-weight: 400;
  color: #b5aa94;
  letter-spacing: 0.2rpx;
}

.meta-stats {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.meta-stat {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meta-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.5;
}

.meta-num {
  font-size: 24rpx;
  font-weight: 500;
  color: #b5aa94;
  letter-spacing: 0.2rpx;
}

/* ── 删除按钮 ── */
.delete-btn {
  position: absolute;
  top: 16rpx;
  right: 4rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.delete-btn:active {
  opacity: 0.4;
}

.delete-icon {
  width: 36rpx;
  height: 36rpx;
}
