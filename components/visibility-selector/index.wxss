.selector {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
}

.option {
  height: 60rpx;
  box-sizing: border-box;
  border: 2rpx solid #eadfb8;
  border-radius: 999rpx;
  background: #fffdf7;
  color: #5f584a;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.active {
  border-color: #e7b900;
  background: #ffd84d;
  color: #15130d;
  font-weight: 800;
}
