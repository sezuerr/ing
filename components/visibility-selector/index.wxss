.selector {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.option {
  height: 78rpx;
  box-sizing: border-box;
  border: 2rpx solid #eadfb8;
  border-radius: 14rpx;
  background: #fffdf7;
  color: #5f584a;
  font-size: 26rpx;
  line-height: 74rpx;
  padding: 0 10rpx;
}

.active {
  border-color: #e7b900;
  background: #ffd84d;
  color: #15130d;
  font-weight: 800;
}
