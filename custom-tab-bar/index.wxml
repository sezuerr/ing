<view class="tabbar">
  <block wx:for="{{list}}" wx:key="pagePath">
    <view class="tab {{selected === index ? 'active' : ''}} {{item.center ? 'center' : ''}}" data-index="{{index}}" bindtap="switchTab">
      <view wx:if="{{item.center}}" class="publish-fab">
        <view class="plus-h"></view>
        <view class="plus-v"></view>
      </view>
      <image wx:else class="tab-icon" src="{{selected === index ? item.iconFill : item.iconLine}}" mode="aspectFit" />
    </view>
  </block>
</view>
