.tabbar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 100;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  height: 126rpx;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 2rpx solid rgba(21, 19, 13, 0.08);
  background: rgba(250, 250, 247, 0.96);
  box-shadow: 0 -12rpx 40rpx rgba(21, 19, 13, 0.06);
}

.tab {
  position: relative;
  display: flex;
  min-width: 0;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  color: #766f60;
}

.tab-icon {
  width: 58rpx;
  height: 58rpx;
}

.active {
  color: #15130d;
  font-weight: 700;
}

.center {
  transform: translateY(-24rpx);
}

.publish-fab {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  border: 6rpx solid #fff8dc;
  border-radius: 999rpx;
  background: #ffd84d;
  box-shadow: 0 14rpx 28rpx rgba(225, 168, 0, 0.28);
}

.plus-h,
.plus-v {
  position: absolute;
  top: 50%;
  left: 50%;
  border-radius: 999rpx;
  background: #15130d;
  transform: translate(-50%, -50%);
}

.plus-h {
  width: 42rpx;
  height: 6rpx;
}

.plus-v {
  width: 6rpx;
  height: 42rpx;
}
