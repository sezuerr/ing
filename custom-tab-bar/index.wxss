.tabbar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 100;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  height: 126rpx;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 2rpx solid rgba(255, 193, 7, 0.12);
  background: rgba(255, 249, 230, 0.96);
  backdrop-filter: saturate(180%) blur(20rpx);
  -webkit-backdrop-filter: saturate(180%) blur(20rpx);
  box-shadow: 0 -8rpx 32rpx rgba(255, 193, 7, 0.08);
}

.tab {
  position: relative;
  display: flex;
  min-width: 0;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  color: #766f60;
}

.tab-icon {
  width: 58rpx;
  height: 58rpx;
}

.active {
  color: #15130d;
  font-weight: 700;
}

.center {
  transform: translateY(-24rpx);
}

.publish-fab {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  border: 6rpx solid #fff8dc;
  border-radius: 999rpx;
  background: #FFD700;
  box-shadow: 0 14rpx 28rpx rgba(255, 215, 0, 0.35);
}

.plus-h,
.plus-v {
  position: absolute;
  top: 50%;
  left: 50%;
  border-radius: 999rpx;
  background: #15130d;
  transform: translate(-50%, -50%);
}

.plus-h {
  width: 42rpx;
  height: 6rpx;
}

.plus-v {
  width: 6rpx;
  height: 42rpx;
}
