<wxs module="swipe" src="./swipe.wxs"></wxs>
<view class="page discover-page">
  <view class="discover-top" style="padding-top: {{statusBarHeight - 45}}px;">
    <image class="top-logo" src="/icons/ing_logo.png" mode="aspectFit" />
    <view class="top-bar">
      <view class="scope-toggle-row">
        <view
          class="scope-toggle {{scopeMode === 'university' ? 'on' : ''}}"
          data-mode="university"
          catchtap="switchScopeMode">
          <text>大学</text>
        </view>
        <view
          class="scope-toggle {{scopeMode === 'city' ? 'on' : ''}}"
          data-mode="city"
          catchtap="switchScopeMode">
          <text>同城</text>
        </view>
      </view>
      <view class="filter-icon-wrapper" catchtap="openFilter">
        <view class="filter-icon">
          <view class="filter-line filter-line-top"></view>
          <view class="filter-line filter-line-mid"></view>
          <view class="filter-line filter-line-bot"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="card-stack-area">
    <view wx:if="{{currentPost}}" class="swipe-area">
      <view class="card-stack">
        <view wx:if="{{nextPost}}" class="card-layer card-behind">
          <post-card post="{{nextPost}}" currentUserId="{{currentUserId}}" />
        </view>

        <view class="card-layer card-front"
              data-width="{{windowWidth}}"
              change:prop="{{swipe.reset}}" prop="{{currentIndex}}"
              bindtouchstart="{{swipe.touchStart}}"
              bindtouchmove="{{swipe.touchMove}}"
              bindtouchend="{{swipe.touchEnd}}">
          <post-card post="{{currentPost}}" currentUserId="{{currentUserId}}" myNickName="{{myNickName}}" myAvatarUrl="{{myAvatarUrl}}" bind:like="likePost" bind:reply="replyPost" bind:report="reportPost" bind:gochat="goChat" />
        </view>
      </view>
      <view class="swipe-tip">左划看下一张 · 不可回退</view>
    </view>

    <view wx:else class="empty panel">
      <view class="empty-icon">💡</view>
      <view class="empty-title">附近暂时安静</view>
      <view class="empty-copy">换个范围，或者发布一个此刻的想法。</view>
    </view>
  </view>

  <!-- 筛选浮层 -->
  <view class="sheet-mask {{filterVisible ? 'show' : ''}}" catchtap="closeFilter"></view>
  <view class="sheet {{filterVisible ? 'show' : ''}}" catchtap="noop">
    <view class="sheet-header">
      <view class="sheet-grabber"></view>
      <view class="sheet-header-row">
        <view class="sheet-title">筛选</view>
        <view class="sheet-close" catchtap="closeFilter">完成</view>
      </view>
    </view>

    <scroll-view class="sheet-body" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="group-label">话题</view>
      <view class="group">
        <view class="cell" catchtap="toggleTopicOnly">
          <view class="cell-title">只看随机话题</view>
          <image class="toggle" src="{{topicOnly ? '/icons/toggle-fill.svg' : '/icons/toggle-line.svg'}}" mode="aspectFit" />
        </view>
      </view>
      <view class="topic-filter-row">
        <view
          wx:for="{{topicIcons}}"
          wx:key="*this"
          class="topic-filter-icon {{topicSelected[item] ? 'on' : ''}}"
          data-icon="{{item}}"
          catchtap="selectTopic">
          <text class="topic-filter-emoji">{{item}}</text>
        </view>
      </view>

    </scroll-view>
  </view>

  <!-- 举报浮层 -->
  <view class="sheet-mask {{reportVisible ? 'show' : ''}}" catchtap="closeReport"></view>
  <view class="sheet report-sheet {{reportVisible ? 'show' : ''}}" catchtap="noop">
    <view class="sheet-header">
      <view class="sheet-grabber"></view>
      <view class="sheet-header-row">
        <view class="sheet-title">举报</view>
        <view class="sheet-close" catchtap="closeReport">取消</view>
      </view>
    </view>
    <scroll-view class="sheet-body" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="report-reason-list">
        <view
          wx:for="{{reportReasons}}"
          wx:key="value"
          class="report-reason-item"
          data-value="{{item.value}}"
          catchtap="submitReport">
          <text class="report-reason-label">{{item.label}}</text>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
