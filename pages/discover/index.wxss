@keyframes breathe {
  0%, 100% { transform: scale(1); opacity: 0.8; box-shadow: 0 0 16rpx rgba(255, 193, 7, 0.4), 0 0 40rpx rgba(255, 152, 0, 0.2); }
  50% { transform: scale(1.12); opacity: 1; box-shadow: 0 0 28rpx rgba(255, 193, 7, 0.7), 0 0 60rpx rgba(255, 152, 0, 0.35); }
}

@keyframes markerPulse {
  0%, 100% { transform: scale(1); opacity: 0.5; }
  50% { transform: scale(1.6); opacity: 0.15; }
}

.discover-page {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
  padding: calc(56rpx + env(safe-area-inset-top)) 28rpx calc(148rpx + env(safe-area-inset-bottom));
  background: linear-gradient(160deg, #FFF5E1 0%, #FFD700 35%, #FFECB3 60%, #FFB6C1 100%);
  height: 100vh;
  overflow: hidden;
}

/* ===== 顶部安全区行 ===== */
.discover-top {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding-bottom: 8rpx;
  flex: 0 0 auto;
  position: relative;
  z-index: 10;
}

/* ===== 卡片居中容器 ===== */
.card-stack-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 0;
}

/* ===== 大学/同城切换 ===== */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  gap: 20rpx;
}

.scope-toggle-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(14rpx);
  -webkit-backdrop-filter: blur(14rpx);
  padding: 4rpx;
  position: relative;
  z-index: 10;
}

.scope-toggle {
  padding: 10rpx 30rpx;
  border-radius: 999rpx;
  color: var(--color-text-secondary);
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.28s ease;
}

.scope-toggle.on {
  background: var(--color-accent-gradient);
  color: var(--color-text-primary);
  font-weight: 800;
  box-shadow: 0 4rpx 16rpx rgba(255, 152, 0, 0.3);
}

/* ===== 顶部操作按钮组 ===== */
.top-row-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
  align-self: flex-start;
}

/* 筛选图标容器样式 */
.filter-icon-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(14rpx);
  -webkit-backdrop-filter: blur(14rpx);
  color: var(--color-text-primary, #333333);
  transition: opacity 0.2s ease;
}

.filter-icon-wrapper:active {
  opacity: 0.6;
}

.filter-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
  width: 36rpx;
}

.filter-line {
  height: 4rpx;
  border-radius: 2rpx;
  background: currentColor;
}

.filter-line-top {
  width: 100%;
}

.filter-line-mid {
  width: 66%;
}

.filter-line-bot {
  width: 33%;
}

/* ===== 卡片区域 ===== */
.swipe-area {
  width: 100%;
}

.card-stack {
  position: relative;
}

.card-layer {
  will-change: transform, opacity;
}

.card-behind {
  position: absolute;
  top: 0;
  right: 0;
  left: 0;
  z-index: 1;
  transform: scale(0.94);
  opacity: 0.6;
}

.card-front {
  position: relative;
  z-index: 2;
  transform-origin: center bottom;
}

.swipe-tip {
  margin-top: 22rpx;
  color: #ad9f7b;
  font-size: 24rpx;
  text-align: center;
}

/* ==================== 空状态 ==================== */
.empty {
  margin-top: 88rpx;
  padding: 56rpx 28rpx;
  border: 0;
  border-radius: 28rpx;
  text-align: center;
}

.empty-icon {
  font-size: 68rpx;
}

.empty-title {
  margin-top: 12rpx;
  color: var(--color-text-primary);
  font-size: 34rpx;
  font-weight: 900;
}

.empty-copy {
  margin-top: 10rpx;
  color: var(--color-text-tertiary);
  font-size: 26rpx;
}

/* ==================== 筛选浮层 ==================== */
.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(21, 19, 13, 0.4);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s ease;
}

.sheet-mask.show {
  opacity: 1;
  visibility: visible;
}

.sheet {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 101;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  height: 60vh;
  max-height: 900rpx;
  padding: 0 28rpx calc(40rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: rgba(242, 241, 236, 0.97);
  backdrop-filter: saturate(180%) blur(20rpx);
  -webkit-backdrop-filter: saturate(180%) blur(20rpx);
  transform: translateY(100%);
  transition: transform 0.28s ease;
}

.sheet.show {
  transform: translateY(0);
}

.sheet-grabber {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto;
  border-radius: 999rpx;
  background: rgba(21, 19, 13, 0.18);
}

.sheet-header {
  flex: 0 0 auto;
  padding: 16rpx 0 0;
}

.sheet-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 4rpx 24rpx;
}

.sheet-body {
  flex: 1 1 auto;
  min-height: 0;
}

.sheet-title {
  color: var(--color-text-primary);
  font-size: 34rpx;
  font-weight: 900;
}

.sheet-close {
  color: var(--color-text-secondary);
  font-size: 30rpx;
  font-weight: 700;
}

.group-label {
  margin: 0 8rpx 12rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.group-label:not(:first-of-type) {
  margin-top: 32rpx;
}

.group {
  overflow: hidden;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(21, 19, 13, 0.05);
}

.cell {
  position: relative;
  display: flex;
  box-sizing: border-box;
  width: 100%;
  min-height: 104rpx;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
}

.hairline::before {
  content: "";
  position: absolute;
  right: 0;
  bottom: 0;
  left: 28rpx;
  border-bottom: 2rpx solid rgba(21, 19, 13, 0.07);
}

.cell-title {
  color: var(--color-text-primary);
  font-size: 30rpx;
  font-weight: 500;
}

.toggle {
  width: 84rpx;
  height: 48rpx;
}

.topic-filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
  padding: 0 8rpx;
}

.topic-filter-icon {
  display: flex;
  width: 88rpx;
  height: 88rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 14rpx rgba(21, 19, 13, 0.08);
  transition: all 0.25s ease;
}

.topic-filter-icon.on {
  background: linear-gradient(135deg, #ffd84d, #ffb300);
  box-shadow: 0 6rpx 20rpx rgba(255, 193, 7, 0.45);
  transform: scale(1.1);
}

.topic-filter-emoji {
  font-size: 36rpx;
  line-height: 1;
}

.check {
  width: 24rpx;
  height: 14rpx;
  border-left: 5rpx solid #15130d;
  border-bottom: 5rpx solid #15130d;
  border-radius: 2rpx;
  transform: rotate(-45deg);
  margin-bottom: 6rpx;
}

/* ===== 举报浮层 ===== */
.report-sheet .sheet-body {
  padding-bottom: 40rpx;
}

.report-reason-list {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.report-reason-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 248, 0.6);
  cursor: pointer;
}

.report-reason-item:active {
  background: rgba(255, 216, 77, 0.2);
}

.report-reason-label {
  color: #342e22;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 40rpx;
}
