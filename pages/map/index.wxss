/* ==================== 页面背景 ==================== */
.map-page {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
}

/* ==================== 原生地图 ==================== */
.campus-map {
  width: 100%;
  height: 100%;
}

.map-hint {
  position: absolute;
  right: 0;
  bottom: 40rpx;
  left: 0;
  z-index: 6;
  padding: 12rpx 0;
  color: rgba(0, 0, 0, 0.25);
  font-size: 22rpx;
  text-align: center;
  pointer-events: none;
}
