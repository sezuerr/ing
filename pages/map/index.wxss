.map-page {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
}

.map-page .top-logo {
  position: absolute;
  top: calc(88rpx + env(safe-area-inset-top));
  left: 28rpx;
  z-index: 10;
  margin-bottom: 0;
  filter: drop-shadow(0 2rpx 6rpx rgba(0,0,0,0.25));
}

.campus-map {
  width: 100%;
  height: 100%;
}

/* 修复: popover 展示时用占位块撑开布局，map 已被 wx:if 移除 */
.map-placeholder {
  width: 100%;
  height: 100%;
  background: #f5f0e5;
}

@keyframes popoverFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes popoverScaleIn {
  from { transform: scale(0.88); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.popover-overlay {
  position: fixed;
  inset: 0;
  z-index: 60;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 28rpx calc(60rpx + env(safe-area-inset-bottom));
  background: rgba(21, 19, 13, 0.45);
  backdrop-filter: blur(6rpx);
  -webkit-backdrop-filter: blur(6rpx);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.popover-overlay.show {
  opacity: 1;
  visibility: visible;
}

.popover-card-wrapper {
  position: relative;
  width: 100%;
  max-width: 640rpx;
  animation: popoverScaleIn 0.32s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.popover-overlay.show .popover-card-wrapper {
  animation: popoverScaleIn 0.32s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.popover-card-close {
  position: absolute;
  top: -20rpx;
  right: -12rpx;
  z-index: 10;
  display: flex;
  width: 64rpx;
  height: 64rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--color-accent-light), var(--color-accent-dark));
  box-shadow: 0 4rpx 16rpx rgba(255, 193, 7, 0.4);
}

.popover-card-close:active {
  transform: scale(0.9);
  opacity: 0.8;
}

.popover-card-close-x {
  color: var(--color-text-primary);
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1;
}
