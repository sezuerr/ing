/* ===== 地图 Marker Q弹浮动 ===== */
@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  30% { transform: translateY(-16rpx); }
  50% { transform: translateY(-4rpx); }
  70% { transform: translateY(-12rpx); }
}

@keyframes glowPulse {
  0%, 100% { transform: scale(1); opacity: 0.7; }
  50% { transform: scale(1.4); opacity: 1; }
}

@keyframes clusterGlow {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.5); opacity: 1; }
}

@keyframes popIn {
  0% { transform: translate(-50%, -50%) scale(0.8); opacity: 0; }
  65% { transform: translate(-50%, -50%) scale(1.04); opacity: 1; }
  100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
}

/* ==================== 页面背景 — 糖果薄暮 ==================== */
.map-page {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #F4F4FC 0%, #E8E0F8 25%, #E0F7FA 65%, #F8F4FF 100%);
}

/* ==================== 地图区域 ==================== */
.map-container {
  flex: 1;
  position: relative;
  overflow: hidden;
}

.map-canvas {
  width: 100%;
  height: 100%;
}

.map-surface {
  width: 750rpx;
  height: 1200rpx;
}

.map-bg {
  position: absolute;
  inset: 0;
}

.map-bg-glow {
  position: absolute;
  border-radius: 50%;
}

.map-bg-glow-1 {
  width: 500rpx;
  height: 500rpx;
  top: 80rpx;
  left: 80rpx;
  background: radial-gradient(circle, rgba(255, 218, 185, 0.4) 0%, transparent 70%);
}

.map-bg-glow-2 {
  width: 450rpx;
  height: 450rpx;
  top: 520rpx;
  left: 280rpx;
  background: radial-gradient(circle, rgba(230, 230, 250, 0.45) 0%, transparent 70%);
}

.map-bg-glow-3 {
  width: 380rpx;
  height: 380rpx;
  top: 200rpx;
  left: 380rpx;
  background: radial-gradient(circle, rgba(255, 240, 245, 0.4) 0%, transparent 70%);
}

/* ==================== Marker 通用 ==================== */
.map-marker {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  animation: bounce 2.6s ease-in-out infinite;
}

.map-marker-cluster {
  animation: none;
}

.marker-glow-ring {
  position: absolute;
  top: -10rpx;
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 215, 0, 0.35) 0%, transparent 70%);
  animation: glowPulse 2.2s ease-in-out infinite;
  z-index: 0;
}

.marker-glow-ring-cluster {
  top: -20rpx;
  width: 120rpx;
  height: 120rpx;
  background: radial-gradient(circle, rgba(255, 215, 0, 0.5) 0%, rgba(255, 215, 0, 0.12) 50%, transparent 70%);
  animation: clusterGlow 2s ease-in-out infinite;
}

/* ===== Single 小灯泡 ===== */
.marker-dot {
  position: relative;
  z-index: 1;
  display: flex;
  width: 48rpx;
  height: 48rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: transparent;
  filter: drop-shadow(0 0 14rpx rgba(255, 215, 0, 0.9)) drop-shadow(0 0 28rpx rgba(255, 215, 0, 0.5));
}

.marker-emoji {
  font-size: 24rpx;
  line-height: 1;
  z-index: 1;
  background: #FFD700;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 0 18rpx rgba(255, 215, 0, 0.7),
    0 0 36rpx rgba(255, 215, 0, 0.4),
    0 0 56rpx rgba(255, 215, 0, 0.2);
}

/* ===== Cluster 大聚合体 ===== */
.marker-dot-cluster {
  width: 80rpx;
  height: 80rpx;
  background: transparent;
  filter: drop-shadow(0 0 22rpx rgba(255, 215, 0, 1)) drop-shadow(0 0 44rpx rgba(255, 215, 0, 0.7)) drop-shadow(0 0 66rpx rgba(255, 215, 0, 0.4));
}

.marker-emoji-cluster {
  width: 80rpx;
  height: 80rpx;
  font-size: 40rpx;
  background: #FFD700;
  box-shadow:
    0 0 28rpx rgba(255, 215, 0, 0.9),
    0 0 56rpx rgba(255, 215, 0, 0.5),
    0 0 84rpx rgba(255, 215, 0, 0.25);
}

.cluster-badge {
  position: absolute;
  top: -6rpx;
  right: -8rpx;
  z-index: 3;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #15130d;
  font-size: 20rpx;
  font-weight: 800;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}

.marker-label-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}

.marker-label {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  white-space: nowrap;
}

.marker-landmark {
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.55);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  color: #4a4a4a;
  font-size: 18rpx;
  font-weight: 500;
  white-space: nowrap;
}

.map-hint {
  position: absolute;
  right: 0;
  bottom: 40rpx;
  left: 0;
  z-index: 6;
  padding: 12rpx 0;
  color: rgba(0, 0, 0, 0.25);
  font-size: 22rpx;
  text-align: center;
  pointer-events: none;
}
