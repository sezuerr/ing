.quick-row {
  display: flex;
  padding: 40rpx 40rpx;
  margin-bottom: 32rpx;
}

.quick-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
}

.quick-icon {
  position: relative;
  display: flex;
  width: 110rpx;
  height: 110rpx;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
}

.quick-icon-glyph {
  width: 52rpx;
  height: 52rpx;
}

.quick-icon-like {
  background: rgba(255, 103, 77, 0.14);
  color: #ff674d;
}

.quick-icon-reply {
  background: rgba(74, 144, 226, 0.14);
  color: #4a90e2;
}

.quick-icon-match {
  background: rgba(255, 216, 77, 0.24);
  color: #b8860b;
}

.quick-dot {
  position: absolute;
  top: 2rpx;
  right: 2rpx;
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid #fafaf7;
  border-radius: 999rpx;
  background: #ff4d4f;
}

.quick-label {
  margin-top: 12rpx;
  color: #15130d;
  font-size: 28rpx;
  font-weight: 450;
}

.messages-page .section-title {
  margin-bottom: 6rpx;
  color: #8a806d;
  font-size: 24rpx;
  font-weight: 600;
}

.list {
  background: transparent;
}

.empty-row {
  padding: 34rpx 4rpx;
  color: #8a806d;
  font-size: 26rpx;
  text-align: center;
}
