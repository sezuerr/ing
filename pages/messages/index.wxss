.messages-page {
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--color-surface);
  padding: calc(100rpx + env(safe-area-inset-top)) 28rpx calc(148rpx + env(safe-area-inset-bottom));
}

.quick-row {
  display: flex;
  padding: 40rpx 16rpx;
  margin-bottom: 32rpx;
  gap: 12rpx;
}

.quick-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
}

.quick-icon {
  position: relative;
  display: flex;
  width: 110rpx;
  height: 110rpx;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(21, 19, 13, 0.05);
}

.quick-icon-glyph {
  width: 52rpx;
  height: 52rpx;
}

.quick-icon-like {
  background: linear-gradient(135deg, var(--color-danger-soft), rgba(255, 152, 0, 0.12));
  color: var(--color-danger-light);
}

.quick-icon-reply {
  background: linear-gradient(135deg, var(--color-info-soft), rgba(100, 180, 255, 0.1));
  color: var(--color-info);
}

.quick-icon-match {
  background: linear-gradient(135deg, rgba(255, 216, 77, 0.28), rgba(255, 193, 7, 0.18));
  box-shadow: 0 8rpx 24rpx rgba(255, 193, 7, 0.18);
  color: #b8860b;
}

.quick-dot {
  position: absolute;
  top: 2rpx;
  right: 2rpx;
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid var(--color-surface);
  border-radius: 999rpx;
  background: var(--color-danger);
}

.quick-label {
  margin-top: 12rpx;
  color: var(--color-text-primary);
  font-size: 28rpx;
  font-weight: 450;
}

.messages-page .section-title {
  margin-bottom: 6rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
  font-weight: 600;
}

.list {
  background: transparent;
}

.empty-row {
  padding: 34rpx 4rpx;
  color: var(--color-text-secondary);
  font-size: 26rpx;
  text-align: center;
}
