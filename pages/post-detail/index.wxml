<view class="page detail-page" wx:if="{{post}}">
  <view class="back-row" catchtap="goBack">
    <text class="back-arrow">←</text>
    <text class="back-label">返回</text>
  </view>

  <!-- 自己的帖子：干净布局 -->
  <block wx:if="{{isMine}}">
    <view class="mine-detail">
      <view class="mine-header">
        <view class="mine-avatar">
          <image wx:if="{{authorAvatar}}" src="{{authorAvatar}}" mode="aspectFill" />
          <text wx:else class="mine-avatar-text">{{avatarText}}</text>
        </view>
        <text class="mine-nickname">{{authorName}}</text>
      </view>

      <view class="mine-content-card">
        <view class="title-row">
          <view class="topic-badge">
            <text class="topic-badge-icon">{{post.icon || '💡'}}</text>
          </view>
          <text class="mine-title">{{post.title}}</text>
        </view>
        <text class="mine-body">{{post.body}}</text>
        <scroll-view wx:if="{{post.imageUrls && post.imageUrls.length > 1}}" scroll-x class="images">
          <image wx:for="{{post.imageUrls}}" wx:key="*this" class="image" mode="aspectFill" src="{{item}}" />
        </scroll-view>

        <!-- 点亮 / 回复 标签栏 -->
        <view class="mine-tabs">
          <view class="mine-tab {{tabActive === 'likes' ? 'active' : ''}}" data-tab="likes" catchtap="switchTab">
            <text class="mine-tab-text">{{post.likeCount || 0}} 点亮</text>
            <view wx:if="{{tabActive === 'likes'}}" class="mine-tab-indicator" />
          </view>
          <view class="mine-tab {{tabActive === 'replies' ? 'active' : ''}}" data-tab="replies" catchtap="switchTab">
            <text class="mine-tab-text">{{post.commentCount || 0}} 回复</text>
            <view wx:if="{{tabActive === 'replies'}}" class="mine-tab-indicator" />
          </view>
        </view>

        <!-- 点亮列表 -->
        <view wx:if="{{tabActive === 'likes'}}" class="mine-likers-list">
          <block wx:if="{{likers.length}}">
            <view wx:for="{{likers}}" wx:key="_id" class="mine-liker-row">
              <view class="mine-liker-avatar {{item.fromUser.isFriend ? 'is-friend' : ''}}">
                <image wx:if="{{item.fromUser.isFriend && item.fromUser.avatarUrl}}" src="{{item.fromUser.avatarUrl}}" mode="aspectFill" />
                <text wx:else>{{item.fromUser.isFriend && item.fromUser.nickName ? item.fromUser.nickName.slice(0,1) : '?'}}</text>
              </view>
              <text class="mine-liker-name {{item.fromUser.isFriend ? '' : 'anonymous'}}">{{item.fromUser.isFriend && item.fromUser.nickName ? item.fromUser.nickName : '匿名同学'}}</text>
              <view wx:if="{{item.fromUser.isFriend}}" class="mine-liker-arrow" data-liker="{{item.fromUser}}" catchtap="openLikerProfile">
                <text>›</text>
              </view>
            </view>
          </block>
          <view wx:else class="mine-empty-tab">
            <text>暂无点亮</text>
          </view>
        </view>

        <!-- 回复列表 -->
        <view wx:if="{{tabActive === 'replies'}}" class="mine-comments-section">
          <block wx:if="{{comments.length}}">
            <view wx:for="{{comments}}" wx:key="_id" class="mine-comment">
              <view class="mine-comment-avatar">{{item.fromUser && item.fromUser.nickName ? item.fromUser.nickName.slice(0,1) : '匿'}}</view>
              <view class="mine-comment-right">
                <view class="mine-comment-name">{{item.fromUser ? (item.fromUser.nickName || '好友') : '好友'}}</view>
                <text class="mine-comment-body">{{item.content}}</text>
              </view>
            </view>
          </block>
          <view wx:else class="mine-empty-tab">
            <text>暂无回复</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 别人的帖子：复用卡片组件 -->
  <block wx:else>
    <view class="card-wrapper">
      <post-card
        post="{{post}}"
        comments="{{comments}}"
        currentUserId="{{currentUserId}}"
        bind:like="onLike"
        bind:match="onMatch"
        bind:reply="onReply"
        bind:gochat="onGoChat"
        bind:report="onReport"
      />
    </view>

    <!-- 举报浮层 -->
    <view class="sheet-mask {{reportVisible ? 'show' : ''}}" catchtap="closeReport"></view>
    <view class="sheet report-sheet {{reportVisible ? 'show' : ''}}" catchtap="noop">
      <view class="sheet-header">
        <view class="sheet-grabber"></view>
        <view class="sheet-header-row">
          <view class="sheet-title">举报</view>
          <view class="sheet-close" catchtap="closeReport">取消</view>
        </view>
      </view>
      <scroll-view class="sheet-body" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="report-reason-list">
          <view
            wx:for="{{reportReasons}}"
            wx:key="value"
            class="report-reason-item"
            data-value="{{item.value}}"
            catchtap="submitReport">
            <text class="report-reason-label">{{item.label}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </block>
</view>
