.detail-page {
  background: #f2f1ec;
  padding-top: calc(80rpx + env(safe-area-inset-top));
}

.back-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 0 28rpx 16rpx;
  cursor: pointer;
}

.back-row:active {
  opacity: 0.6;
}

.back-arrow {
  color: #15130d;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
}

.back-label {
  color: #15130d;
  font-size: 30rpx;
  font-weight: 700;
}

/* ========== 自己的帖子 ========== */
.mine-detail {
  padding: 0 28rpx;
}

.mine-content-card {
  padding: 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.mine-card-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding-bottom: 20rpx;
}

.mine-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 999rpx;
  background: #f2f1ec;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex: 0 0 auto;
}

.mine-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 999rpx;
}

.mine-avatar-text {
  font-size: 34rpx;
  font-weight: 900;
  color: #15130d;
}

.mine-nickname {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #15130d;
}

.mine-delete-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  flex: 0 0 auto;
}

.mine-delete-btn:active {
  opacity: 0.45;
}

.mine-delete-icon {
  width: 40rpx;
  height: 40rpx;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.topic-badge {
  display: flex;
  width: 56rpx;
  height: 56rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #fff3c4, #ffe8a0);
  box-shadow: 0 4rpx 12rpx rgba(255, 193, 7, 0.2);
}

.topic-badge-icon {
  font-size: 28rpx;
  line-height: 1;
}

.mine-title {
  flex: 1;
  color: #15130d;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 54rpx;
}

.mine-body {
  display: block;
  margin-top: 27rpx;
  color: #342e22;
  font-size: 32rpx;
  line-height: 42rpx;
  white-space: pre-wrap;
}

.images {
  width: 100%;
  margin-top: 20rpx;
  white-space: nowrap;
}

.image {
  width: 360rpx;
  height: 270rpx;
  margin-right: 14rpx;
  border-radius: 14rpx;
  background: #eee3bf;
  display: inline-block;
}

/* 点亮 / 回复 标签栏 */
.mine-tabs {
  display: flex;
  margin-top: 24rpx;
  padding: 0 4rpx;
  border-bottom: 2rpx solid var(--color-border);
}

.mine-tab {
  position: relative;
  padding: 20rpx 0 16rpx;
  margin-right: 44rpx;
}

.mine-tab-text {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-secondary);
}

.mine-tab.active .mine-tab-text {
  color: var(--color-text-primary);
}

.mine-tab-indicator {
  position: absolute;
  left: 0;
  right: 0;
  bottom: -2rpx;
  height: 4rpx;
  border-radius: 2rpx;
  background: var(--color-accent-gradient);
}

/* 点亮列表 */
.mine-likers-list {
  margin: 0 -28rpx;
}

.mine-liker-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 28rpx;
  border-bottom: 1rpx solid rgba(235, 210, 140, 0.15);
}

.mine-liker-row:last-child {
  border-bottom: 0;
}

.mine-liker-avatar {
  display: flex;
  width: 72rpx;
  height: 72rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ddd8c8, #b8b0a0);
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
  overflow: hidden;
}

.mine-liker-avatar.is-friend {
  background: linear-gradient(135deg, #15130d, #342e22);
  color: #ffd84d;
}

.mine-liker-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 999rpx;
}

.mine-liker-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #15130d;
}

.mine-liker-name.anonymous {
  color: #8a806d;
}

.mine-liker-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  font-size: 36rpx;
  color: #bbb09a;
}

/* 回复列表 */
.mine-comments-section {
  margin: 0 -28rpx;
  padding: 8rpx 28rpx;
}

.mine-comment {
  display: flex;
  gap: 12rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(235, 210, 140, 0.2);
}

.mine-comment:last-child {
  border-bottom: 0;
}

.mine-comment-avatar {
  display: flex;
  width: 48rpx;
  height: 48rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #15130d, #342e22);
  color: #ffd84d;
  font-size: 22rpx;
  font-weight: 800;
}

.mine-comment-right {
  flex: 1;
  min-width: 0;
}

.mine-comment-name {
  color: #15130d;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 32rpx;
}

.mine-comment-body {
  display: block;
  margin-top: 2rpx;
  color: #6f6656;
  font-size: 24rpx;
  line-height: 36rpx;
}

.mine-empty-tab {
  padding: 40rpx 28rpx;
  text-align: center;
  color: #8a806d;
  font-size: 26rpx;
}

/* ========== 别人的帖子 ========== */
.card-wrapper {
  margin-bottom: 28rpx;
}

/* ===== 举报浮层 ===== */
.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(21, 19, 13, 0.4);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s ease;
}

.sheet-mask.show {
  opacity: 1;
  visibility: visible;
}

.sheet {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 101;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  height: 60vh;
  max-height: 900rpx;
  padding: 0 28rpx calc(40rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: rgba(242, 241, 236, 0.97);
  backdrop-filter: saturate(180%) blur(20rpx);
  -webkit-backdrop-filter: saturate(180%) blur(20rpx);
  transform: translateY(100%);
  transition: transform 0.28s ease;
}

.sheet.show {
  transform: translateY(0);
}

.sheet-grabber {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto;
  border-radius: 999rpx;
  background: rgba(21, 19, 13, 0.18);
}

.sheet-header {
  flex: 0 0 auto;
  padding: 16rpx 0 0;
}

.sheet-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 4rpx 24rpx;
}

.sheet-body {
  flex: 1 1 auto;
  min-height: 0;
}

.sheet-title {
  color: #15130d;
  font-size: 34rpx;
  font-weight: 900;
}

.sheet-close {
  color: #8a806d;
  font-size: 30rpx;
  font-weight: 700;
}

.report-sheet .sheet-body {
  padding-bottom: 40rpx;
}

.report-reason-list {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.report-reason-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 248, 0.6);
  cursor: pointer;
}

.report-reason-item:active {
  background: rgba(255, 216, 77, 0.2);
}

.report-reason-label {
  color: #342e22;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 40rpx;
}
