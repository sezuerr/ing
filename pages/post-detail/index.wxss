.post {
  padding: 28rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.82);
  backdrop-filter: saturate(180%) blur(20rpx);
  -webkit-backdrop-filter: saturate(180%) blur(20rpx);
  box-shadow:
    0 16rpx 48rpx rgba(255, 193, 7, 0.1),
    0 4rpx 14rpx rgba(21, 19, 13, 0.05);
}

.author-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-bottom: 24rpx;
  margin-bottom: 24rpx;
  border-bottom: 2rpx solid rgba(255, 193, 7, 0.12);
}

.author-avatar {
  display: flex;
  width: 72rpx;
  height: 72rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #15130d, #342e22);
  color: #ffd84d;
  font-size: 32rpx;
  font-weight: 800;
}

.author-info {
  flex: 1;
  min-width: 0;
}

.author-name {
  color: #15130d;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 38rpx;
}

.author-meta {
  color: #8a806d;
  font-size: 22rpx;
  line-height: 30rpx;
}

.landmark {
  margin-bottom: 18rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 193, 7, 0.12);
  display: inline-block;
  color: #b8860b;
  font-size: 24rpx;
  font-weight: 600;
}

.title-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.icon {
  font-size: 52rpx;
}

.title {
  flex: 1;
  color: #15130d;
  font-size: 42rpx;
  font-weight: 950;
  line-height: 54rpx;
}

.body {
  display: block;
  margin-top: 22rpx;
  color: #342e22;
  font-size: 30rpx;
  line-height: 52rpx;
  white-space: pre-wrap;
}

.images {
  width: 100%;
  margin-top: 24rpx;
  white-space: nowrap;
}

.image {
  width: 360rpx;
  height: 270rpx;
  margin-right: 14rpx;
  border-radius: 18rpx;
  display: inline-block;
}

.meta-stats {
  display: flex;
  gap: 24rpx;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(255, 193, 7, 0.12);
}

.stat {
  color: #8a806d;
  font-size: 24rpx;
}

.vis-tag {
  margin-left: auto;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 193, 7, 0.12);
  color: #b8860b;
  font-size: 22rpx;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 24rpx;
}

.action {
  display: flex;
  height: 88rpx;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
  border: 2rpx solid rgba(255, 193, 7, 0.15);
  background: #f2efe3;
  color: #15130d;
}

.action.like {
  border-color: #e7b900;
  background: #ffd84d;
  box-shadow: 0 4rpx 16rpx rgba(255, 193, 7, 0.25);
}

.action.liked {
  border-color: transparent;
  background: linear-gradient(135deg, #ffd84d, #ffb300);
  box-shadow: 0 4rpx 16rpx rgba(255, 193, 7, 0.3);
  color: #15130d;
}

.comments {
  padding: 0;
  border-radius: 24rpx;
}

.comment {
  display: flex;
  gap: 16rpx;
  padding: 22rpx 24rpx;
  border-bottom: 2rpx solid rgba(255, 193, 7, 0.12);
}

.comment:last-child {
  border-bottom: 0;
}

.comment-avatar {
  display: flex;
  width: 64rpx;
  height: 64rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #15130d, #342e22);
  color: #ffd84d;
  font-size: 26rpx;
  font-weight: 800;
}

.comment-right {
  flex: 1;
  min-width: 0;
}

.comment-name {
  color: #15130d;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 36rpx;
}

.comment-body {
  display: block;
  margin-top: 4rpx;
  color: #6f6656;
  font-size: 26rpx;
  line-height: 38rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 32rpx;
  text-align: center;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  color: #15130d;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.empty-desc {
  color: #8a806d;
  font-size: 24rpx;
  line-height: 36rpx;
}

.report-entry {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 88rpx;
  margin-top: 28rpx;
  color: #aaa18e;
  font-size: 26rpx;
}
