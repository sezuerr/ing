.detail-page {
  background: #f2f1ec;
  padding-top: calc(120rpx + env(safe-area-inset-top));
}

.back-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 0 0 16rpx 0;
  cursor: pointer;
}

.back-row:active {
  opacity: 0.6;
}

.back-arrow {
  color: #15130d;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
}

.back-label {
  color: #15130d;
  font-size: 30rpx;
  font-weight: 700;
}

.card-wrapper {
  margin-bottom: 28rpx;
}

.section {
  margin-top: 28rpx;
}

.section-title {
  color: #15130d;
  font-size: 28rpx;
  font-weight: 800;
  margin-bottom: 16rpx;
}

.comments {
  padding: 0;
  border-radius: 6rpx 32rpx 6rpx 32rpx;
  background: linear-gradient(170deg, #fffef8 0%, #fff9e5 35%, #fff3d4 100%);
  box-shadow:
    3rpx 4rpx 0 rgba(200, 160, 40, 0.1),
    6rpx 8rpx 18rpx rgba(0, 0, 0, 0.04),
    8rpx 12rpx 36rpx rgba(53, 42, 14, 0.06);
  border: 1rpx solid rgba(235, 210, 140, 0.3);
}

.comment {
  display: flex;
  gap: 16rpx;
  padding: 22rpx 24rpx;
  border-bottom: 2rpx solid rgba(255, 193, 7, 0.12);
}

.comment:last-child {
  border-bottom: 0;
}

.comment-avatar {
  display: flex;
  width: 64rpx;
  height: 64rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #15130d, #342e22);
  color: #ffd84d;
  font-size: 26rpx;
  font-weight: 800;
}

.comment-right {
  flex: 1;
  min-width: 0;
}

.comment-name {
  color: #15130d;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 36rpx;
}

.comment-body {
  display: block;
  margin-top: 4rpx;
  color: #6f6656;
  font-size: 26rpx;
  line-height: 38rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 32rpx;
  text-align: center;
  border-radius: 6rpx 32rpx 6rpx 32rpx;
  background: linear-gradient(170deg, #fffef8 0%, #fff9e5 35%, #fff3d4 100%);
  box-shadow:
    3rpx 4rpx 0 rgba(200, 160, 40, 0.1),
    6rpx 8rpx 18rpx rgba(0, 0, 0, 0.04),
    8rpx 12rpx 36rpx rgba(53, 42, 14, 0.06);
  border: 1rpx solid rgba(235, 210, 140, 0.3);
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  color: #15130d;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.empty-desc {
  color: #8a806d;
  font-size: 24rpx;
  line-height: 36rpx;
}

/* ===== 举报浮层 ===== */
.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(21, 19, 13, 0.4);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s ease;
}

.sheet-mask.show {
  opacity: 1;
  visibility: visible;
}

.sheet {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 101;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  height: 60vh;
  max-height: 900rpx;
  padding: 0 28rpx calc(40rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: rgba(242, 241, 236, 0.97);
  backdrop-filter: saturate(180%) blur(20rpx);
  -webkit-backdrop-filter: saturate(180%) blur(20rpx);
  transform: translateY(100%);
  transition: transform 0.28s ease;
}

.sheet.show {
  transform: translateY(0);
}

.sheet-grabber {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto;
  border-radius: 999rpx;
  background: rgba(21, 19, 13, 0.18);
}

.sheet-header {
  flex: 0 0 auto;
  padding: 16rpx 0 0;
}

.sheet-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 4rpx 24rpx;
}

.sheet-body {
  flex: 1 1 auto;
  min-height: 0;
}

.sheet-title {
  color: #15130d;
  font-size: 34rpx;
  font-weight: 900;
}

.sheet-close {
  color: #8a806d;
  font-size: 30rpx;
  font-weight: 700;
}

.report-sheet .sheet-body {
  padding-bottom: 40rpx;
}

.report-reason-list {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.report-reason-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 248, 0.6);
  cursor: pointer;
}

.report-reason-item:active {
  background: rgba(255, 216, 77, 0.2);
}

.report-reason-label {
  color: #342e22;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 40rpx;
}
