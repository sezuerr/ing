<view class="page profile-page">
  <view class="corner-bulb" catchtap="goHome">
    <image class="footer-icon" src="/icons/lightbulb-fill.svg" mode="aspectFit"></image>
  </view>
  <view class="header">
    <view class="header-top">
      <view class="profile-copy">
        <view class="name">{{user.nickName || '小黄灯'}}</view>
        <view class="bio">{{user.bio || '还没有写简介'}}</view>
      </view>
      <view class="avatar">
        <image wx:if="{{user.avatarUrl}}" src="{{user.avatarUrl}}" mode="aspectFill" />
        <text wx:else>{{avatarText}}</text>
      </view>
    </view>
    <view class="stats-row">
      <text class="stats-text">获赞 {{user.stats.likeCount || 0}} · 评论 {{user.stats.commentCount || 0}}</text>
      <view class="settings-entry" bindtap="openSettings">
        <text class="settings-text">设置</text>
        <image class="settings-icon" src="/icons/settings-4-line.svg" mode="aspectFit" />
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-tabs">
      <view class="tab active">帖子</view>
    </view>
    <view class="list">
      <post-list-item wx:for="{{posts}}" wx:key="_id" post="{{item}}" bind:open="openPost" />
      <view wx:if="{{!posts.length}}" class="empty-row">还没有发布内容</view>
    </view>
  </view>
</view>
