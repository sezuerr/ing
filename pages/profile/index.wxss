/* ── 页面容器 ── */
.profile-page {
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--color-surface);
  padding: calc(100rpx + env(safe-area-inset-top)) 28rpx 0;
}

/* ── 个人资料头部 ── */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 8rpx 12rpx;
}

/* 头像 */
.avatar-wrap {
  margin-bottom: 20rpx;
}

.avatar {
  width: 176rpx;
  height: 176rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #15130d, #342e22);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  font-size: 42rpx;
  font-weight: 900;
  color: var(--color-accent-light);
  letter-spacing: 1rpx;
}

/* 名字 & 简介 */
.profile-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  letter-spacing: 0.5rpx;
  line-height: 1.2;
}

.profile-bio {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.45;
  max-width: 480rpx;
}

/* 编辑资料按钮 */
.edit-profile-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 64rpx;
  padding: 0 32rpx;
  border-radius: 999rpx;
  border: 2rpx solid var(--color-border-strong);
  background: rgba(255, 255, 255, 0.6);
  transition: all 0.2s;
}

.edit-profile-btn:active {
  background: var(--color-accent-soft);
  border-color: var(--color-accent);
  transform: scale(0.97);
}

.edit-icon {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.edit-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
}

/* ── 数据统计卡片 ── */
.stats-card {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 28rpx;
  padding: 24rpx 32rpx;
  background: var(--color-card-panel);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  border-radius: 28rpx;
  border: 2rpx solid var(--color-accent-border);
  box-shadow:
    0 8rpx 32rpx rgba(255, 193, 7, 0.06),
    0 2rpx 8rpx rgba(21, 19, 13, 0.04);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  flex: 1;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--color-text-primary);
  line-height: 1.1;
}

.stat-label {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  letter-spacing: 1rpx;
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: rgba(255, 193, 7, 0.12);
  flex: 0 0 auto;
}

/* ── 内容标签栏 ── */
.content-tabs {
  display: flex;
  margin-top: 32rpx;
  padding: 0 4rpx;
  border-bottom: 2rpx solid var(--color-border);
}

.tab {
  position: relative;
  padding: 16rpx 0;
  margin-right: 44rpx;
}

.tab-text {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.tab-indicator {
  position: absolute;
  left: 0;
  right: 0;
  bottom: -2rpx;
  height: 4rpx;
  border-radius: 2rpx;
  background: var(--color-accent-gradient);
}

/* ── 帖子列表 ── */
.post-list {
  padding: 8rpx 0;
}

/* ── 空状态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 40rpx;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 216, 77, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-icon {
  font-size: 56rpx;
  line-height: 1;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 28rpx;
  text-align: center;
}

.empty-action {
  height: 72rpx;
  padding: 0 40rpx;
  border-radius: 999rpx;
  border: 0;
  background: var(--color-accent-gradient);
  color: var(--color-text-primary);
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(255, 152, 0, 0.28);
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-action:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 14rpx rgba(255, 152, 0, 0.2);
}

/* ── 底部占位 ── */
.bottom-spacer {
  height: calc(148rpx + env(safe-area-inset-bottom));
}
