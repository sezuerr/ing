.editor {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: saturate(180%) blur(20rpx);
  -webkit-backdrop-filter: saturate(180%) blur(20rpx);
  border-radius: 32rpx;
  box-shadow:
    0 16rpx 48rpx rgba(255, 193, 7, 0.1),
    0 4rpx 14rpx rgba(21, 19, 13, 0.05);
}

.topic-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.title-input {
  min-width: 0;
  flex: 1;
  height: 88rpx;
  color: #15130d;
  font-size: 34rpx;
  font-weight: 900;
}

.content-input {
  margin-top: 24rpx;
  border: 0;
  background: transparent;
}

.images {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.image,
.image-btn {
  width: 156rpx;
  height: 156rpx;
  border-radius: 18rpx;
}

.image {
  background: linear-gradient(135deg, #ffe8a0, #ffd84d);
}

.image-btn {
  border: 2rpx dashed #e0c060;
  background: rgba(255, 248, 220, 0.6);
  color: #b8860b;
  font-size: 24rpx;
  line-height: 152rpx;
  padding: 0;
}

.privacy {
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 8rpx 24rpx rgba(255, 193, 7, 0.06);
}

.location {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  color: #7d735e;
  font-size: 24rpx;
}

.locate {
  width: 150rpx;
  height: 58rpx;
  margin: 0;
  font-size: 22rpx;
  line-height: 54rpx;
  padding: 0;
}

.submit {
  margin-top: 28rpx;
  background: linear-gradient(135deg, #ffc107, #ff9800) !important;
  box-shadow: 0 12rpx 28rpx rgba(255, 152, 0, 0.28) !important;
}
