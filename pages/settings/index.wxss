.settings-page {
  background: #f2f1ec;
  padding-top: calc(120rpx + env(safe-area-inset-top));
}

/* 返回按钮 */
.back-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 24rpx;
  cursor: pointer;
}

.back-row:active {
  opacity: 0.6;
}

.back-arrow {
  color: #15130d;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
}

.back-label {
  color: #15130d;
  font-size: 30rpx;
  font-weight: 700;
}

/* 分组标题 */
.group-label {
  margin: 0 8rpx 12rpx;
  color: #8a806d;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* 卡片容器 */
.group {
  overflow: hidden;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(21, 19, 13, 0.05);
}

/* 卡片下方灰色说明 */
.group-note {
  margin: 12rpx 8rpx 0;
  color: #8a806d;
  font-size: 24rpx;
  line-height: 34rpx;
}

.group-label:not(:first-of-type) {
  margin-top: 36rpx;
}

/* 通用行 */
.cell {
  position: relative;
  display: flex;
  box-sizing: border-box;
  width: 100%;
  min-height: 104rpx;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
}

/* 铺满整行的透明点击层（用于 chooseAvatar 等需要 button 的场景） */
.cell-tap {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 2;
  width: 100%;
  height: 100%;
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
}

.cell-tap::after {
  border: 0;
}

/* picker / button 外壳需撑满宽度 */
.cell-picker {
  display: block;
  width: 100%;
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  line-height: normal;
  text-align: left;
}

.cell-picker::after {
  border: 0;
}

.hairline {
  position: relative;
}

.hairline::before {
  content: "";
  position: absolute;
  right: 0;
  bottom: 0;
  left: 28rpx;
  border-bottom: 2rpx solid rgba(21, 19, 13, 0.07);
}

.cell-title {
  flex: 0 0 auto;
  color: #15130d;
  font-size: 30rpx;
  font-weight: 500;
}

.cell-value {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 10rpx;
}

.cell-value-text {
  overflow: hidden;
  color: #8a806d;
  font-size: 30rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cell-value-text.placeholder {
  color: #b5ac95;
}

.cell-input {
  flex: 1;
  margin-left: 32rpx;
  color: #15130d;
  font-size: 30rpx;
  text-align: right;
}

/* CSS 箭头 */
.chevron {
  width: 16rpx;
  height: 16rpx;
  flex: 0 0 auto;
  border-top: 4rpx solid #c2b9a4;
  border-right: 4rpx solid #c2b9a4;
  border-radius: 2rpx;
  transform: rotate(45deg);
}

/* 堆叠内容行（简介） */
.cell-stack {
  padding: 24rpx 28rpx;
}

.bio {
  width: 100%;
  box-sizing: border-box;
  min-height: 150rpx;
  color: #15130d;
  font-size: 30rpx;
  line-height: 44rpx;
}

.counter {
  margin-top: 8rpx;
  color: #8a806d;
  font-size: 22rpx;
  text-align: right;
}

.save {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  margin-top: 44rpx;
  border-radius: 999rpx;
  background: #ffd84d;
  color: #15130d;
  font-size: 30rpx;
  font-weight: 800;
  line-height: normal;
  box-shadow: 0 12rpx 26rpx rgba(235, 180, 0, 0.22);
}

.save::after {
  border: 0;
}

.logout-area {
  padding-top: 32rpx;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #c62828;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.logout-btn::after {
  border: 0;
}
