<view class="page profile-page">
  <!-- 返回按钮 -->
  <view class="back-row" catchtap="onBackTap" hover-class="back-row-hover">
    <text class="back-arrow">←</text>
    <text class="back-label">返回</text>
  </view>

  <!-- 个人资料头部 -->
  <view class="profile-header">
    <!-- 头像区 -->
    <view class="avatar-wrap">
      <view class="avatar">
        <image wx:if="{{user.avatarUrl}}" src="{{user.avatarUrl}}" mode="aspectFill" />
        <text wx:else class="avatar-placeholder">{{avatarText}}</text>
      </view>
    </view>

    <!-- 名字 & 简介 -->
    <view class="profile-info">
      <text class="profile-name">{{user.nickName || '同学'}}</text>
      <text class="profile-bio">{{user.bio || '还没有写简介'}}</text>
    </view>
  </view>

  <!-- 内容标签栏 -->
  <view class="content-tabs">
    <view class="tab active">
      <text class="tab-text">帖子</text>
      <view class="tab-indicator" />
    </view>
  </view>

  <!-- 帖子列表（不显示点亮数/评论数） -->
  <view class="post-list">
    <block wx:if="{{posts.length}}">
      <post-list-item
        wx:for="{{posts}}"
        wx:key="_id"
        post="{{item}}"
        showStats="{{false}}"
        bind:open="openPost"
      />
    </block>

    <!-- 空状态 -->
    <view wx:else class="empty-state">
      <view class="empty-icon-wrap">
        <text class="empty-icon">📝</text>
      </view>
      <text class="empty-title">还没有发布内容</text>
      <text class="empty-desc">TA 还没有发布过帖子</text>
    </view>
  </view>

  <!-- 底部安全区占位 -->
  <view class="bottom-spacer" />
</view>
