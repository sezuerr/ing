/* ── 页面容器 ── */
.profile-page {
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--color-surface);
  padding: calc(140rpx + env(safe-area-inset-top)) 28rpx 0;
}

/* ── 返回按钮 ── */
.back-row {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 20rpx;
  margin-left: 8rpx;
  margin-bottom: 8rpx;
}

.back-row-hover {
  opacity: 0.5;
}

.back-arrow {
  color: var(--color-text-primary);
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
  margin-right: 6rpx;
}

.back-label {
  color: var(--color-text-secondary);
  font-size: 26rpx;
  font-weight: 500;
}

/* ── 个人资料头部 ── */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 8rpx 12rpx;
}

/* 头像 */
.avatar-wrap {
  margin-bottom: 20rpx;
}

.avatar {
  width: 176rpx;
  height: 176rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #15130d, #342e22);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  font-size: 42rpx;
  font-weight: 900;
  color: var(--color-accent-light);
  letter-spacing: 1rpx;
}

/* 名字 & 简介 */
.profile-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  letter-spacing: 0.5rpx;
  line-height: 1.2;
}

.profile-bio {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.45;
  max-width: 480rpx;
}

/* ── 内容标签栏 ── */
.content-tabs {
  display: flex;
  margin-top: 32rpx;
  padding: 0 4rpx;
  border-bottom: 2rpx solid var(--color-border);
}

.tab {
  position: relative;
  padding: 16rpx 0;
  margin-right: 44rpx;
}

.tab-text {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.tab-indicator {
  position: absolute;
  left: 0;
  right: 0;
  bottom: -2rpx;
  height: 4rpx;
  border-radius: 2rpx;
  background: var(--color-accent-gradient);
}

/* ── 帖子列表 ── */
.post-list {
  padding: 8rpx 0;
}

/* ── 空状态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 40rpx;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 216, 77, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-icon {
  font-size: 56rpx;
  line-height: 1;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 28rpx;
  text-align: center;
}

/* ── 底部占位 ── */
.bottom-spacer {
  height: calc(148rpx + env(safe-area-inset-bottom));
}
